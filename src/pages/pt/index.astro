---
import { getEntry, render } from "astro:content";

import IndexView from "../../views/index/view.astro";

const homePageEntry = await getEntry("homePages", Astro.currentLocale!);

if (homePageEntry === undefined) {
  return Astro.redirect("/404");
}

const { Content } = await render(homePageEntry);
---

<IndexView title={homePageEntry.data.title}>
  <Content />
</IndexView>
