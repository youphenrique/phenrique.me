---
import { getCollection } from "astro:content";

import dict from "../../../i18n/linkbio/pt";
import LinkbioView from "../../../views/linkbio/view.astro";

const page = await getCollection("linkbioPages", (collection) => collection.id === "pt");

if (page.length === 0) {
  return Astro.redirect("/404");
}

const allSocialLinks = await getCollection("socialLinks");

const socialLinks = allSocialLinks.sort((a, b) => a.id.localeCompare(b.id));
---

<LinkbioView page={page[0]} socialLinks={socialLinks} dict={dict} />
