---
import { css } from "../../../../styled-system/css";
import { hstack } from "../../../../styled-system/patterns";
import type { LinkbioDictionary } from "../../../i18n/linkbio/en.ts";

type Language = { id: string; name: string };

interface Props {
  locale: string;
  dict: LinkbioDictionary;
  languages: Language[];
  linkbioUrl: string;
}

const { locale, dict, languages, linkbioUrl } = Astro.props;

const shareLinks = [
  {
    id: "x-twitter",
    name: "X (Twitter)",
    href: `https://x.com/intent/tweet?text=${dict["top-menu"].menu["link-text"]}! - ${linkbioUrl}`,
    iconHtml: `<svg viewBox="0 0 48 48"><circle cx="50%" cy="50%" r="50%" fill="black"></circle><path d="M11.559 12.251L20.825 25.1736L11.5 35.6775H13.6L21.763 26.4794L28.359 35.6786H35.5L25.712 22.029L34.392 12.25H32.293L24.775 20.7211L18.7 12.251H11.559ZM14.645 13.8625H17.925L32.413 34.0661H29.133L14.644 13.8635L14.645 13.8625Z" fill="white"></path></svg>`,
  },
  {
    id: "whatsapp",
    name: "WhatsApp",
    href: `https://wa.me/?text=${dict["top-menu"].menu["link-text"]}! - ${linkbioUrl}`,
    iconHtml: `<svg viewBox="0 0 24 24"><circle cx="50%" cy="50%" r="50%" fill="#22C55E"></circle><path d="M16.201 7.746a5.9 5.9 0 0 0-4.205-1.745c-3.276 0-5.945 2.669-5.948 5.945 0 1.049.274 2.07.793 2.973L6 18.001l3.153-.826a5.95 5.95 0 0 0 2.843.724h.003c3.275 0 5.944-2.669 5.947-5.948A5.92 5.92 0 0 0 16.2 7.746m-4.205 9.146c-.89 0-1.76-.24-2.518-.69l-.18-.108-1.87.49.5-1.824-.118-.188a4.9 4.9 0 0 1-.755-2.63 4.95 4.95 0 0 1 4.944-4.937c1.32 0 2.56.516 3.495 1.448a4.92 4.92 0 0 1 1.445 3.496 4.95 4.95 0 0 1-4.943 4.943m2.711-3.7a27 27 0 0 0-1.015-.485c-.137-.049-.236-.074-.334.074-.1.148-.384.485-.47.582-.085.1-.174.11-.322.037s-.627-.231-1.195-.739a4.5 4.5 0 0 1-.827-1.029c-.085-.148-.008-.228.066-.302.066-.066.148-.174.223-.26.074-.085.1-.148.148-.248s.025-.185-.012-.259-.333-.807-.459-1.103c-.12-.291-.242-.251-.333-.254C10.09 9.2 9.99 9.2 9.892 9.2c-.1 0-.26.037-.397.185-.136.149-.519.508-.519 1.24 0 .733.534 1.438.608 1.537.074.1 1.046 1.6 2.537 2.244.354.154.63.245.847.314.356.114.678.097.935.06.285-.043.878-.36 1.004-.707.122-.348.122-.645.085-.707-.037-.063-.137-.1-.285-.174" fill="#fff"></path></svg>`,
  },
  {
    id: "linkedin",
    name: "LinkedIn",
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${linkbioUrl}`,
    iconHtml: `<svg viewBox="0 0 24 24"><circle cx="50%" cy="50%" r="50%" fill="#0A66C2"></circle><path d="M8.656 10.132h-2.46V18h2.46zm.221-2.705A1.417 1.417 0 0 0 7.47 6h-.044a1.426 1.426 0 0 0 0 2.852A1.416 1.416 0 0 0 8.877 7.47zM18 13.22c0-2.365-1.505-3.285-3-3.285a2.8 2.8 0 0 0-2.488 1.269h-.07v-1.072h-2.31V18h2.458v-4.186a1.633 1.633 0 0 1 1.476-1.76h.093c.782 0 1.362.492 1.362 1.731V18h2.46z" fill="#fff"></path></svg>`,
  },
  {
    id: "email",
    name: "E-mail",
    href: `mailto:?subject=${dict["top-menu"].menu["link-text"]}!&body=${dict["top-menu"].menu["link-text"]} - ${linkbioUrl}`,
    iconHtml: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="12" fill="#60696c"/><g transform="translate(4.5 4.5)"><path d="M1 2C0.447715 2 0 2.44772 0 3V12C0 12.5523 0.447715 13 1 13H14C14.5523 13 15 12.5523 15 12V3C15 2.44772 14.5523 2 14 2H1ZM1 3L14 3V3.92494C13.9174 3.92486 13.8338 3.94751 13.7589 3.99505L7.5 7.96703L1.24112 3.99505C1.16621 3.94751 1.0826 3.92486 1 3.92494V3ZM1 4.90797V12H14V4.90797L7.74112 8.87995C7.59394 8.97335 7.40606 8.97335 7.25888 8.87995L1 4.90797Z" fill="white" fill-rule="evenodd" clip-rule="evenodd"/></g></svg>`,
  },
];

const popoverHeaderClass = css({
  p: 2,
  fontSize: "xs",
  color: "#fffcf4b0",
  fontWeight: "medium",
  textTransform: "uppercase",
});

const itemClass = css({
  p: 2,
  width: "full",
  color: "#EEE",
  borderRadius: "md",
  display: "flex",
  alignItems: "center",
  justifyContent: "space-between",
  transition: "background-color 0.15s ease-in-out",
  _hover: { bg: "neutral.700", cursor: "default" },
  textDecoration: "none",
  textAlign: "left",
  background: "none",
  border: "none",
  font: "inherit",
});

const shareItemClass = hstack({
  p: 2,
  width: "full",
  color: "#EEE",
  borderRadius: "md",
  display: "flex",
  alignItems: "center",
  justifyContent: "space-between",
  transition: "background-color 0.15s ease-in-out",
  _hover: { bg: "neutral.700", cursor: "default" },
  textDecoration: "none",
  textAlign: "left",
  background: "none",
  border: "none",
  font: "inherit",
  gap: 2,
});

const checkIconSvg = `<svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M11.4669 3.72684C11.7558 3.91574 11.8369 4.30308 11.648 4.59198L7.39799 11.092C7.29783 11.2452 7.13556 11.3467 6.95402 11.3699C6.77247 11.3931 6.58989 11.3355 6.45446 11.2124L3.70446 8.71241C3.44905 8.48022 3.43023 8.08494 3.66242 7.82953C3.89461 7.57412 4.28989 7.55529 4.5453 7.78749L6.75292 9.79441L10.6018 3.90792C10.7907 3.61902 11.178 3.53795 11.4669 3.72684Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"></path></svg>`;

const externalLinkSvg = `<svg width="7" height="7" viewBox="0 0 6 6" aria-hidden="true"><path d="M1.25215 5.54731L0.622742 4.9179L3.78169 1.75597H1.3834L1.38936 0.890915H5.27615V4.78069H4.40513L4.41109 2.38538L1.25215 5.54731Z" fill="#EEE"></path></svg>`;

const copyIconSvg = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="12" fill="#e0e2d9"/><g transform="translate(4.5 4.5)"><path d="M4.62471 4.00001L4.56402 4.00001C4.04134 3.99993 3.70687 3.99988 3.4182 4.055C2.2379 4.28039 1.29846 5.17053 1.05815 6.33035C0.999538 6.61321 0.999604 6.93998 0.999703 7.43689L0.999711 7.50001L0.999703 7.56313C0.999604 8.06004 0.999538 8.38681 1.05815 8.66967C1.29846 9.8295 2.2379 10.7196 3.4182 10.945C3.70688 11.0001 4.04135 11.0001 4.56403 11L4.62471 11H5.49971C5.77585 11 5.99971 10.7762 5.99971 10.5C5.99971 10.2239 5.77585 10 5.49971 10H4.62471C4.02084 10 3.78907 9.99777 3.60577 9.96277C2.80262 9.8094 2.19157 9.21108 2.03735 8.46678C2.00233 8.29778 1.99971 8.08251 1.99971 7.50001C1.99971 6.91752 2.00233 6.70225 2.03735 6.53324C2.19157 5.78895 2.80262 5.19062 3.60577 5.03725C3.78907 5.00225 4.02084 5.00001 4.62471 5.00001H5.49971C5.77585 5.00001 5.99971 4.77615 5.99971 4.50001C5.99971 4.22387 5.77585 4.00001 5.49971 4.00001H4.62471ZM10.3747 5.00001C10.9786 5.00001 11.2104 5.00225 11.3937 5.03725C12.1968 5.19062 12.8079 5.78895 12.9621 6.53324C12.9971 6.70225 12.9997 6.91752 12.9997 7.50001C12.9997 8.08251 12.9971 8.29778 12.9621 8.46678C12.8079 9.21108 12.1968 9.8094 11.3937 9.96277C11.2104 9.99777 10.9786 10 10.3747 10H9.49971C9.22357 10 8.99971 10.2239 8.99971 10.5C8.99971 10.7762 9.22357 11 9.49971 11H10.3747L10.4354 11C10.9581 11.0001 11.2925 11.0001 11.5812 10.945C12.7615 10.7196 13.701 9.8295 13.9413 8.66967C13.9999 8.38681 13.9998 8.06005 13.9997 7.56314L13.9997 7.50001L13.9997 7.43688C13.9998 6.93998 13.9999 6.61321 13.9413 6.33035C13.701 5.17053 12.7615 4.28039 11.5812 4.055C11.2925 3.99988 10.9581 3.99993 10.4354 4.00001L10.3747 4.00001H9.49971C9.22357 4.00001 8.99971 4.22387 8.99971 4.50001C8.99971 4.77615 9.22357 5.00001 9.49971 5.00001H10.3747ZM5.00038 7C4.72424 7 4.50038 7.22386 4.50038 7.5C4.50038 7.77614 4.72424 8 5.00038 8H10.0004C10.2765 8 10.5004 7.77614 10.5004 7.5C10.5004 7.22386 10.2765 7 10.0004 7H5.00038Z" fill="black" fill-rule="evenodd" clip-rule="evenodd"/></g></svg>`;

const menuIconSvg = `<svg viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg" width="15" height="15"><path d="M1.5 3C1.22386 3 1 3.22386 1 3.5C1 3.77614 1.22386 4 1.5 4H13.5C13.7761 4 14 3.77614 14 3.5C14 3.22386 13.7761 3 13.5 3H1.5ZM1 7.5C1 7.22386 1.22386 7 1.5 7H13.5C13.7761 7 14 7.22386 14 7.5C14 7.77614 13.7761 8 13.5 8H1.5C1.22386 8 1 7.77614 1 7.5ZM1 11.5C1 11.2239 1.22386 11 1.5 11H13.5C13.7761 11 14 11.2239 14 11.5C14 11.7761 13.7761 12 13.5 12H1.5C1.22386 12 1 11.7761 1 11.5Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"></path></svg>`;
---

<div
  lang={locale}
  class={css({
    mb: 6,
    display: "flex",
    justifyContent: "flex-end",
  })}
>
  <button
    id="top-menu-trigger"
    popovertarget="top-menu-popover"
    aria-label={dict["top-menu"]["menu-label"]}
    class={css({
      width: 10,
      height: 10,
      display: "flex",
      cursor: "pointer",
      alignItems: "center",
      borderRadius: "full",
      justifyContent: "center",
      backgroundColor: "zinc.800",
      transition: "background-color 0.15s ease-in-out",
      _hover: {
        backgroundColor: "zinc.900",
      },
    })}
  >
    <span
      class={css({
        width: 5,
        height: 5,
        display: "block",
        color: "white",
      })}
      set:html={menuIconSvg}
    />
  </button>

  <div
    id="top-menu-popover"
    popover="auto"
    class={css({
      m: 0,
      p: 1,
      minW: 48,
      boxShadow: "2xl",
      borderRadius: "lg",
      border: "1px solid",
      bg: "neutral.800",
      borderColor: "rgb(37, 37, 37)",
      position: "absolute",
      top: "auto",
      right: "1rem",
      marginTop: "2",
      "&:popover-open": {
        display: "block",
      },
    })}
  >
    <div>
      <header class={popoverHeaderClass}>{dict["top-menu"].menu.language}</header>
      {
        languages.map((language) => (
          <a href={language.id === "en" ? "/linkbio" : `/linkbio/${language.id}`} class={itemClass}>
            <span>{language.name}</span>
            {language.id === locale && <span set:html={checkIconSvg} />}
          </a>
        ))
      }
    </div>
    <div>
      <header class={popoverHeaderClass}>{dict["top-menu"].menu.share}</header>
      <button id="copy-linkbio-btn" data-url={linkbioUrl} data-feedback={dict.toast.feedback} class={shareItemClass}>
        <div class={css({ w: 6, h: 6 })} set:html={copyIconSvg} />
        <span>{dict["top-menu"].menu.copy}</span>
      </button>
      {
        shareLinks.map((item) => (
          <a href={item.href} target="_blank" rel="noopener noreferrer" class={shareItemClass}>
            <div class={css({ w: 6, h: 6 })} set:html={item.iconHtml} />
            <span>{item.name}</span>
            <span class={css({ top: -2, left: -1.5, position: "relative" })} set:html={externalLinkSvg} />
          </a>
        ))
      }
    </div>
  </div>
</div>

<div id="linkbio-toast" role="alert" aria-live="assertive" style="display:none"></div>

<style>
  #linkbio-toast {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    font-size: 0.875rem;
    padding: 10px 14px;
    color: #fafafa;
    border-radius: 8px;
    font-weight: 500;
    background-color: #0a0a0a;
    border: 1px solid rgb(42, 42, 42);
    z-index: 100;
    animation: toastIn 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes toastIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  function showToast(message: string) {
    const toast = document.getElementById("linkbio-toast") as HTMLElement;
    if (!toast) return;

    if (toastTimer) {
      clearTimeout(toastTimer);
    }

    toast.textContent = message;
    toast.style.display = "block";

    toastTimer = setTimeout(() => {
      toast.style.display = "none";
      toastTimer = null;
    }, 2500);
  }

  function closeMenu() {
    const popover = document.getElementById("top-menu-popover") as HTMLElement & {
      hidePopover?: () => void;
    };
    popover?.hidePopover?.();
  }

  function initCopyButton() {
    const btn = document.getElementById("copy-linkbio-btn");
    if (!btn) return;

    btn.addEventListener("click", () => {
      const url = btn.getAttribute("data-url") ?? window.location.href;
      const feedback = btn.getAttribute("data-feedback") ?? "Link copied!";

      navigator.clipboard.writeText(url).then(
        () => {
          closeMenu();
          showToast(feedback);
        },
        () => {
          console.warn("Clipboard write failed");
        },
      );
    });
  }

  document.addEventListener("DOMContentLoaded", initCopyButton);
  document.addEventListener("astro:after-swap", initCopyButton);
</script>
