---
import { getCollection, getEntry } from "astro:content";

import dict from "../../../i18n/reading/pt";
import ReadingView from "../../../views/reading/view.astro";

const readingPageEntry = await getEntry("readingPages", Astro.currentLocale!);

if (readingPageEntry === undefined) {
  return Astro.redirect("/404");
}

const allBooks = await getCollection("books");
---

<ReadingView
  dict={dict}
  allBooks={allBooks}
  title={readingPageEntry.data.metadata.title}
  description={readingPageEntry.data.metadata.description}
/>
