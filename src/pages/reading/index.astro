---
import { getCollection, getEntry } from "astro:content";
import MainLayout from "../../layouts/main-layout.astro";
import Container from "../../views/_components/container.astro";
import { vstack, grid } from "../../../styled-system/patterns";
import { css } from "../../../styled-system/css";
import BookPreviewCard from "./_components/book-preview-card.astro";
import BookItem from "./_components/book-item.astro";
import dict from "../../i18n/reading/en";

const LOCALE = "en";
const BLOB_STORAGE_URL = import.meta.env.VERCEL_BLOB_STORAGE_URL ?? "";

const readingPageEntry = await getEntry("readingPages", LOCALE);

if (!readingPageEntry) {
  return Astro.redirect("/404");
}

const allBooks = await getCollection("books");

const currentlyReads = allBooks
  .filter((book) => book.data.status === "reading")
  .map((book) => ({
    ...book.data,
    cover: {
      ...book.data.cover,
      url: book.data.cover.urlPath.startsWith("http")
        ? book.data.cover.urlPath
        : `${BLOB_STORAGE_URL}${book.data.cover.urlPath}`,
    },
    id: book.id,
  }));

const finishedBooks = allBooks
  .filter((book) => book.data.status === "finished")
  .sort((a, b) => {
    if (!a.data.finishedDate || !b.data.finishedDate) return 0;
    return b.data.finishedDate.getTime() - a.data.finishedDate.getTime();
  })
  .map((book) => ({ ...book.data, id: book.id }));
---

<MainLayout title={readingPageEntry.data.metadata.title} description={readingPageEntry.data.metadata.description}>
  <Container>
    <div class={vstack({ mt: 32, alignItems: "stretch", gap: 8 })}>
      <h1
        class={css({
          fontSize: "4xl",
          fontWeight: "semibold",
          color: "clr_neutral_900_50",
          fontFamily: "'Fraunces Variable', serif",
        })}
      >
        {dict["page-title"]}
      </h1>
      <h2
        class={css({
          fontSize: "sm",
          fontWeight: "medium",
          color: "clr_neutral_700_400",
        })}
      >
        {dict["currently-reads"]["section-title"]}
      </h2>
    </div>
    {
      currentlyReads.length === 0 ? (
        <div class={css({ mt: 12, color: "clr_neutral_700_400", textAlign: "center" })}>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class={css({ mx: "auto" })}
          >
            <path d="M12 17h1.5" />
            <path d="M12 22h1.5" />
            <path d="M12 2h1.5" />
            <path d="M17.5 22H19a1 1 0 0 0 1-1" />
            <path d="M17.5 2H19a1 1 0 0 1 1 1v1.5" />
            <path d="M20 14v3h-2.5" />
            <path d="M20 8.5V10" />
            <path d="M4 10V8.5" />
            <path d="M4 19.5V14" />
            <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H8" />
            <path d="M8 22H6.5a1 1 0 0 1 0-5H8" />
          </svg>
          <h3
            class={css({
              mt: 3.5,
              fontWeight: "semibold",
              color: "clr_neutral_800_200",
              fontSize: "sm",
            })}
          >
            {dict["currently-reads"]["no-reads"].title}
          </h3>
          <p
            class={css({
              mt: 1,
              mx: "auto",
              maxW: "16rem",
              fontSize: "sm",
              lineHeight: 1.25,
              color: "clr_neutral_700_400",
            })}
          >
            {dict["currently-reads"]["no-reads"].description}
          </p>
        </div>
      ) : (
        <div
          class={grid({
            mt: 6,
            gap: 8,
            gridTemplateColumns: {
              base: "repeat(1, minmax(0, 1fr))",
              md: "repeat(2, minmax(0, 1fr))",
            },
          })}
        >
          {currentlyReads.map((book) => (
            <BookPreviewCard
              title={book.title}
              genres={book.genres}
              authors={book.authors}
              progress={book.progress}
              coverUrl={book.cover?.url ?? null}
            />
          ))}
        </div>
      )
    }
    <div class={css({ mt: 16 })}>
      <h2
        class={css({
          fontSize: "sm",
          position: "relative",
          fontWeight: "medium",
          color: "clr_neutral_700_400",
          _after: {
            content: '""',
            h: "2px",
            w: "full",
            left: 0,
            right: 0,
            bottom: -2.5,
            display: "block",
            borderRadius: "sm",
            position: "absolute",
            bgColor: "clr_neutral_300_700",
          },
        })}
      >
        {dict["more-reads"]}
      </h2>
      <ul class={vstack({ mt: 8, mb: 20, alignItems: "stretch", gap: { base: 6, lg: 1 } })}>
        {finishedBooks.map((book) => <BookItem title={book.title} authors={book.authors} rating={book.rating ?? 0} />)}
      </ul>
    </div>
  </Container>
</MainLayout>
