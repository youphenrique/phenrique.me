---
import { Image } from "astro:assets";

import { css } from "../../../../styled-system/css";
import { flex, hstack, vstack } from "../../../../styled-system/patterns";
import BookGenreBadge from "./book-genre-badge.astro";

interface Props {
  title: string;
  genres: string[];
  authors: string[];
  coverUrl: string | null;
  progress: number | null;
}

const { title, genres, authors, coverUrl, progress } = Astro.props;
const bookProgress = progress ?? 0;
---

<div
  class={`book-card ${flex({
    boxShadow: "xs",
    borderRadius: "xl",
    border: "1px solid",
    bgColor: "clr_white_neutral_900",
    borderColor: "clr_neutral_300_700",
  })}`}
>
  <Image
    width={539}
    height={784}
    alt={title}
    loading="eager"
    src={coverUrl !== null
      ? `${import.meta.env.PUBLIC_VERCEL_BLOB_STORAGE_URL}${coverUrl}`
      : "/images/book-cover-placeholder.png"}
    class={css({
      borderTopLeftRadius: "xl",
      borderBottomLeftRadius: "xl",
      maxWidth: 28,
      boxShadow: "sm",
      objectFit: "cover",
    })}
  />
  <div
    class={flex({
      flexDirection: "column",
      justifyContent: "space-between",
      px: 5,
      py: 4,
      flex: 1,
      overflow: "hidden",
    })}
  >
    <div class={vstack({ gap: 3, alignItems: "stretch" })}>
      <h3
        title={title}
        class={flex({
          fontSize: "sm",
          lineHeight: 1.3,
          fontWeight: "medium",
          color: "clr_neutral_900_50",
          lineClamp: 2,
          overflow: "hidden",
          boxOrient: "vertical",
          textOverflow: "ellipsis",
        })}
      >
        {title}
      </h3>
      <h4
        class={css({
          fontSize: "sm",
          lineHeight: "tight",
          fontWeight: "medium",
          color: "clr_neutral_700_400",
        })}
      >
        {authors.length === 0 ? "Unknown" : authors.join(", ")}
      </h4>
    </div>
    <div class={vstack({ alignItems: "stretch", width: "full" })}>
      <div
        class={`genre-container ${hstack({
          gap: 2,
          p: 0.5,
          overflowX: "auto",
        })}`}
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >
        {genres.map((genre) => <BookGenreBadge>{genre}</BookGenreBadge>)}
      </div>
      <div class={flex({ gap: 2, alignItems: "center" })}>
        <div
          class={css({
            h: 1,
            w: "full",
            borderRadius: "sm",
            position: "relative",
            bg: "clr_neutral_300_700",
          })}
        >
          <div
            style={{ width: `${bookProgress}%` }}
            class={css({
              h: 1,
              top: 0,
              left: 0,
              display: "block",
              borderRadius: "sm",
              position: "absolute",
              bgColor: "clr_coral_flame",
            })}
          >
          </div>
        </div>
        <span class={css({ fontSize: "sm", color: "clr_neutral_700_400" })}>{bookProgress}%</span>
      </div>
    </div>
  </div>
</div>

<style>
  .genre-container::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function updateOverflow() {
    const containers = document.querySelectorAll(".genre-container");

    containers.forEach((el) => {
      const container = el as HTMLElement;
      const update = () => {
        const maxScroll = container.scrollWidth - container.clientWidth;
        const atStart = container.scrollLeft <= 1;
        const atEnd = container.scrollLeft >= maxScroll - 1;

        let gradient;
        if (maxScroll <= 1) {
          gradient = "none";
        } else if (atStart) {
          gradient = "linear-gradient(to right, black 75%, transparent 100%)";
        } else if (atEnd) {
          gradient = "linear-gradient(to left, black 75%, transparent 100%)";
        } else {
          gradient = "linear-gradient(to right, transparent 0, black 2rem, black calc(100% - 2rem), transparent 100%)";
        }

        container.style.maskImage = gradient;
      };

      update();
      container.addEventListener("scroll", update, { passive: true });

      const ro = new ResizeObserver(update);
      ro.observe(container);
    });
  }

  updateOverflow();
  document.addEventListener("astro:after-swap", updateOverflow);
</script>
