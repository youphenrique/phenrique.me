---
import { css } from "../../../styled-system/css";
import MainLayout from "../../layouts/main-layout.astro";
import Container from "../_components/container.astro";

interface Props {
  title: string;
}
---

<MainLayout title="Home" description="Paulo Henrique's personal website" lang={Astro.currentLocale!}>
  <Container styles={css.raw({ py: { base: 32, sm: 44, "2xl": 52 } })}>
    <h1
      class={css({
        fontSize: "4xl",
        color: "clr_neutral_900_50",
        fontFamily: "'Fraunces Variable', serif",
      })}
    >
      {Astro.props.title}
    </h1>
    <div class={"prose-ui antialiased " + css({ mt: 6, maxW: "xl" })}>
      <slot />
    </div>
  </Container>
</MainLayout>
