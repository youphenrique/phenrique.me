---
import type { CollectionEntry } from "astro:content";

import TopMenu from "./_components/top-menu";
import LinkbioLayout from "../../layouts/linkbio-layout.astro";
import Presentation from "./_components/presentation.astro";
import SocialLinks from "./_components/social-links.astro";
import { type LinkbioDictionary } from "../../i18n/linkbio/en";

interface Props {
  dict: LinkbioDictionary;
  page: CollectionEntry<"linkbioPages">;
  socialLinks: CollectionEntry<"socialLinks">[];
}

const { dict } = Astro.props;

const LINKBIO_URL = "https://phenrique.me/linkbio";

