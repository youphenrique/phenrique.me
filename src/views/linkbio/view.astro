      d="M3.33333 7.33348C2.96514 7.33348 2.66667 7.63195 2.66667 8.00014C2.66667 8.36833 2.96514 8.66681 3.33333 8.66681C3.70152 8.66681 4 8.36833 4 8.00014C4 7.63195 3.70152 7.33348 3.33333 7.33348Z"
    ></path>
  </svg>
`;
---

<LinkbioLayout title="Linkbio" description={Astro.props.page.data.metadata.description} locale={Astro.currentLocale!}>
  <TopMenu
    client:only="react"
    dict={dict}
    currentLocale={Astro.currentLocale ?? "en"}
    linkbioUrl={LINKBIO_URL}
    shareLinks={shareLinks}
    icons={{
      check: checkIconSvg,
      copy: copyIconSvg,
      external: externalLinkSvg,
      menu: menuIconSvg,
    }}
  />
  <Presentation
    bioDescription={Astro.props.page.data.bioSection.description}
    bioQuote={Astro.props.page.data.bioSection.quote}
  />
  <SocialLinks
    links={Astro.props.socialLinks.map((socialLink) => ({
      name: socialLink.data.name,
      handle: socialLink.data.handle,
      link: socialLink.data.link,
      logoUrl: socialLink.data.logoUrl,
    }))}
  />
</LinkbioLayout>
