<script is:inline>
  function initHeader() {
    const headerWrapper = document.getElementById("header-wrapper");
    const headerPill = document.getElementById("header-pill");
    const headerRow = document.getElementById("header-row");
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuBarTop = document.getElementById("menu-bar-top");
    const menuBarBottom = document.getElementById("menu-bar-bottom");
    const langMenuBtn = document.getElementById("lang-menu-btn");
    const langMenuContent = document.getElementById("lang-menu-content");

    if (!headerWrapper || !headerPill || !menuToggle || !mobileMenu) return;

    let lastScrollY = 0;
    let scrollTimeout;
    let isMenuOpen = false;

    // --- Scroll hide/show ---
    function handleScroll() {
      clearTimeout(scrollTimeout);

      scrollTimeout = setTimeout(function () {
        const currentScrollY = window.scrollY;
        const diff = Math.abs(currentScrollY - lastScrollY);
        if (currentScrollY > lastScrollY && diff > 50) {
          headerWrapper.style.transform = "translateY(-5rem)";
          if (isMenuOpen) closeMenu();
        } else if (diff > 50 || currentScrollY < 10) {
          headerWrapper.style.transform = "translateY(0)";
        }
        lastScrollY = currentScrollY;
      }, 50);
    }

    window.addEventListener("scroll", handleScroll, { passive: true });

    // --- Mobile menu toggle ---
    function openMenu() {
      isMenuOpen = true;
      mobileMenu.style.display = "grid";
      mobileMenu.style.gridTemplateRows = "1fr";
      headerPill.style.borderRadius = "1.875rem";
      headerRow.style.paddingTop = "16px";
      headerRow.style.paddingInline = "18px";
      menuToggle.setAttribute("aria-expanded", "true");
      if (menuBarTop) menuBarTop.style.transform = "rotate(45deg)";
      if (menuBarBottom) menuBarBottom.style.transform = "rotate(-45deg)";
    }

    function closeMenu() {
      isMenuOpen = false;
      mobileMenu.style.gridTemplateRows = "0fr";
      headerPill.style.borderRadius = "2rem";
      headerRow.style.paddingTop = "7px";
      headerRow.style.paddingInline = "12px";
      menuToggle.setAttribute("aria-expanded", "false");
      if (menuBarTop) menuBarTop.style.transform = "translateY(-4px)";
      if (menuBarBottom) menuBarBottom.style.transform = "translateY(4px)";
    }

    menuToggle.addEventListener("click", function () {
      if (isMenuOpen) closeMenu();
      else openMenu();
    });

    // Close on resize to sm+
    window.addEventListener("resize", function () {
      if (window.innerWidth >= 640 && isMenuOpen) closeMenu();
    });

    // --- Language dropdown ---
    if (langMenuBtn && langMenuContent) {
      function closeLangMenu() {
        langMenuContent.style.display = "none";
        langMenuBtn.setAttribute("aria-expanded", "false");
      }

      langMenuBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        const isOpen = langMenuContent.style.display === "block";
        if (isOpen) {
          closeLangMenu();
        } else {
          langMenuContent.style.display = "block";
          langMenuBtn.setAttribute("aria-expanded", "true");
        }
      });

      document.addEventListener("click", function (e) {
        if (!langMenuContent.contains(e.target) && e.target !== langMenuBtn) {
          closeLangMenu();
        }
      });
    }

    // --- Theme toggle visual state ---
    function updateThemeButtons() {
      const theme = localStorage.getItem("theme") || "system";
      const themeMap = {
        light: ["light-theme-button", "light-theme-button-mobile"],
        system: ["system-theme-button", "system-theme-button-mobile"],
        dark: ["dark-theme-button", "dark-theme-button-mobile"],
      };
      const activeToken = "var(--colors-clr_neutral_300_700)";
      const inactiveToken = "transparent";

      Object.entries(themeMap).forEach(function ([key, ids]) {
        ids.forEach(function (id) {
          const btn = document.getElementById(id);
          if (btn) btn.style.backgroundColor = key === theme ? activeToken : inactiveToken;
        });
      });
    }

    // Mobile theme buttons mirror desktop
    ["light-theme-button-mobile", "system-theme-button-mobile", "dark-theme-button-mobile"].forEach(function (id) {
      const btn = document.getElementById(id);
      if (!btn) return;
      btn.addEventListener("click", function () {
        const desktopId = id.replace("-mobile", "");
        const desktopBtn = document.getElementById(desktopId);
        if (desktopBtn) desktopBtn.click();
      });
    });

    updateThemeButtons();

    // Re-run after theme changes
    const origToggle = window.__themeToggleCallback;
    window.__themeToggleCallback = function () {
      updateThemeButtons();
      if (origToggle) origToggle();
    };
  }

  document.addEventListener("DOMContentLoaded", initHeader);
  document.addEventListener("astro:after-swap", initHeader);
</script>
